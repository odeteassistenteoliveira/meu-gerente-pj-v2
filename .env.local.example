# ─────────────────────────────────────────
# MEU GERENTE PJ — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no Git
# ─────────────────────────────────────────

# SUPABASE — encontre em: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ANTHROPIC (Claude API) — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# APP
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Meu Gerente PJ"

# RESEND (Email transacional) — https://resend.com/api-keys
# Ative em: resend.com → criar conta gratuita → API Keys → Create API Key
RESEND_API_KEY=re_...
FROM_EMAIL="Meu Gerente PJ <contato@meugerentepj.com.br>"

# PLUGGY (Open Finance) — fase 2
# PLUGGY_CLIENT_ID=
# PLUGGY_CLIENT_SECRET=

# ASAAS (Pagamentos) — https://www.asaas.com/
# 1. Crie conta em asaas.com
# 2. Vá em Configurações → Integrações → API
# 3. Gere a chave (começa com $aas_...)
# Sandbox: ASAAS_SANDBOX=true para testes sem cobranças reais
ASAAS_API_KEY=$aas_sua_chave_aqui
ASAAS_SANDBOX=true
# Webhook URL para configurar no Asaas → Configurações → Notificações:
# https://seu-dominio.com/api/webhook/asaas
